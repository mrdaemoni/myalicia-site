---
import Base from './Base.astro';

interface Frontmatter {
  title: string;
  description?: string;
  author?: string;
  date?: string;
  dek?: string;
}

const { frontmatter } = Astro.props as { frontmatter: Frontmatter };
---
<Base title={`${frontmatter.title} — Essays — My Alicia`} description={frontmatter.description}>
  <article class="essay">
    <header class="essay-header">
      {frontmatter.dek && <p class="essay-dek"><em>{frontmatter.dek}</em></p>}
      {(frontmatter.author || frontmatter.date) && (
        <p class="essay-meta">
          {frontmatter.author && <strong>{frontmatter.author}</strong>}
          {frontmatter.author && frontmatter.date && <br />}
          {frontmatter.date && <em>{frontmatter.date}</em>}
        </p>
      )}
    </header>
    <slot />
  </article>
</Base>

<style is:global>
  /* Essay-specific tightenings on top of the global Base styles. */
  article.essay { max-width: 720px; margin: 0 auto; }
  article.essay h1 { font-size: 2rem; margin-bottom: 0.25rem; }
  article.essay h2 {
    font-size: 1.3rem;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  article.essay h3 { font-size: 1.05rem; margin-top: 1.75rem; }
  article.essay .essay-header { margin-bottom: 2.5rem; }
  article.essay .essay-dek {
    font-size: 1.1rem;
    color: var(--ink-soft);
    margin: 0.5rem 0 0.75rem;
  }
  article.essay .essay-meta {
    font-size: 0.95rem;
    color: var(--ink-soft);
    margin: 0 0 0;
  }
  article.essay blockquote {
    border-left: 3px solid var(--accent);
    margin: 1.5rem 0;
    padding: 0.25rem 0 0.25rem 1.25rem;
    color: var(--ink-soft);
    font-style: italic;
  }
  article.essay blockquote p:last-child { margin-bottom: 0; }
  article.essay hr {
    height: 1px;
    background: var(--rule);
    border: none;
    margin: 2.5rem 0;
  }
  article.essay ul, article.essay ol {
    margin: 0 0 1.25rem;
    padding-left: 1.5rem;
  }
  article.essay li { margin-bottom: 0.35rem; }
  article.essay code {
    background: var(--bg-soft);
    padding: 0.1em 0.35em;
    border-radius: 4px;
    font-size: 0.92em;
  }
  /* Footnote refs (markdown footnotes are rendered as <sup><a ...></a></sup>) */
  article.essay sup { font-size: 0.75em; }
  article.essay sup a { text-decoration: none; }
  article.essay .footnotes {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
    font-size: 0.92rem;
    color: var(--ink-soft);
  }
  article.essay .footnotes ol { padding-left: 1.25rem; }
  article.essay .footnotes li { margin-bottom: 0.5rem; }
</style>
