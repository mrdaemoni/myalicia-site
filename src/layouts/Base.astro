---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'My Alicia — the human interface, made buildable',
  description = 'My Alicia is an AI teammate that collaborates with you on your learning journey, transforming knowledge into wisdom. The tangible example of humorphism.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>
      :root {
        --bg: #fafaf7;
        --bg-soft: #f3f1ec;
        --ink: #1a1a1a;
        --ink-soft: #555550;
        --accent: #d97757;
        --rule: #e6e3dc;
        --max: 720px;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
        font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
        font-size: 17px;
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
      }
      main {
        max-width: var(--max);
        margin: 0 auto;
        padding: 4rem 1.5rem 6rem;
      }
      h1, h2, h3 {
        font-weight: 600;
        line-height: 1.25;
        letter-spacing: -0.01em;
      }
      h1 { font-size: 2.4rem; margin: 0 0 0.5rem; }
      h2 { font-size: 1.4rem; margin: 3rem 0 1rem; }
      h3 { font-size: 1.1rem; margin: 2rem 0 0.5rem; }
      p { margin: 0 0 1.25rem; }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      .lede {
        font-size: 1.1rem;
        color: var(--ink-soft);
        margin: 0 0 2.5rem;
      }
      .rule {
        height: 1px;
        background: var(--rule);
        border: none;
        margin: 3rem 0;
      }
      .figure {
        margin: 2rem -0.5rem;
        background: var(--bg-soft);
        border: 1px solid var(--rule);
        border-radius: 8px;
        padding: 1.25rem;
      }
      .figure svg { display: block; max-width: 100%; height: auto; }
      .caption {
        font-size: 0.9rem;
        color: var(--ink-soft);
        margin: 0.75rem 0 0;
        text-align: center;
      }
      .cta {
        display: inline-block;
        background: var(--ink);
        color: var(--bg);
        padding: 0.75rem 1.25rem;
        border-radius: 6px;
        font-weight: 500;
        margin: 1rem 0;
      }
      .cta:hover { text-decoration: none; opacity: 0.9; }
      nav.top {
        max-width: var(--max);
        margin: 0 auto;
        padding: 1.5rem 1.5rem 0;
        font-size: 0.95rem;
      }
      nav.top a { color: var(--ink-soft); margin-right: 1.5rem; }
      /* Dropdown groups: <details> with <summary> for click + keyboard,
         CSS :hover override for desktop pointer users. */
      nav.top details.nav-group {
        display: inline-block;
        position: relative;
        margin-right: 1.5rem;
      }
      nav.top details.nav-group summary {
        cursor: pointer;
        list-style: none;
        color: var(--ink-soft);
        display: inline;
      }
      nav.top details.nav-group summary::-webkit-details-marker { display: none; }
      nav.top details.nav-group summary::after { content: " \25BE"; opacity: 0.55; font-size: 0.85em; }
      nav.top details.nav-group[open] summary::after { content: " \25B4"; opacity: 0.9; }
      nav.top details.nav-group .nav-menu {
        display: none;
        position: absolute;
        top: 1.6em;
        left: -0.6rem;
        background: var(--bg);
        border: 1px solid var(--rule);
        border-radius: 6px;
        padding: 0.4rem 0;
        box-shadow: 0 6px 20px rgba(0,0,0,0.07);
        z-index: 10;
        min-width: 13rem;
      }
      nav.top details.nav-group[open] .nav-menu { display: block; }
      nav.top details.nav-group .nav-menu a {
        display: block;
        margin: 0;
        padding: 0.4rem 1rem;
        white-space: nowrap;
      }
      nav.top details.nav-group .nav-menu a:hover { background: var(--bg-soft); }
      /* Desktop pointer devices: open on hover, no click required. */
      @media (hover: hover) {
        nav.top details.nav-group:hover .nav-menu { display: block; }
        nav.top details.nav-group:hover summary::after { content: " \25B4"; opacity: 0.9; }
      }
      footer {
        max-width: var(--max);
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
        font-size: 0.9rem;
        color: var(--ink-soft);
      }
      /* Mobile: enlarge SVG diagram text so labels are readable
         without pinch-zoom on phones. */
      @media (max-width: 480px) {
        .figure svg text { font-size: 1.15em; }
        body { font-size: 16px; }
        h1 { font-size: 2rem; }
        main { padding: 2.5rem 1.25rem 4rem; }
        nav.top { padding: 1rem 1.25rem 0; font-size: 0.9rem; }
        nav.top a { margin-right: 1rem; }
        nav.top details.nav-group { margin-right: 1rem; }
        nav.top details.nav-group .nav-menu { min-width: 11rem; }
      }
    </style>
  </head>
  <body>
    <nav class="top">
      <a href="/">My Alicia</a>
      <a href="/philosophy">philosophy</a>
      <details class="nav-group">
        <summary>documentation</summary>
        <div class="nav-menu">
          <a href="/documentation/skills-and-capabilities">skills &amp; capabilities</a>
          <a href="/documentation/architecture">architecture</a>
          <a href="/documentation/faq">faq</a>
          <a href="/documentation/papers">papers</a>
        </div>
      </details>
      <details class="nav-group">
        <summary>essays</summary>
        <div class="nav-menu">
          <a href="/essays/the-humorphic-partnership">the humorphic partnership</a>
        </div>
      </details>
      <a href="https://github.com/mrdaemoni/myalicia">github</a>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      <p>
        My Alicia is the tangible example of <a href="https://humorphism.com">humorphism</a>.
        Built on <a href="https://github.com/garrytan">Garry Tan</a>'s thin-harness pattern
        and <a href="https://github.com/karpathy">Andrej Karpathy</a>'s autoresearch idea.
        MIT licensed.
      </p>
    </footer>
  </body>
</html>
