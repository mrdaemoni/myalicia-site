---
/**
 * DrawingDance — a generative, animated line drawing.
 * Lines take the page's font colours (ink / ink-soft / accent) on the page
 * background, slowly weaving and shifting "like a dance". Seeded by `seed`
 * (usually the title or header text) so each drawing is distinct and reflects
 * the words above it. variant: "hero" | "card" | "header".
 */
const { seed = 'alicia', variant = 'header' } = Astro.props;
---
<canvas
  class={`drawing-dance dance-${variant}`}
  data-dance
  data-seed={seed}
  data-variant={variant}
  aria-hidden="true"
></canvas>

<style is:global>
  .drawing-dance { display: block; width: 100%; pointer-events: none; }
  .dance-card   { height: 120px; margin-top: 1.1rem; }
  .dance-hero   { height: 140px; margin: 1.5rem 0 0.5rem; }
  .dance-header { height: 52px; margin: 0.15rem 0 0.4rem; }
  .dance-link   { display: block; }
  @media (max-width: 480px) {
    .dance-card { height: 96px; }
    .dance-hero { height: 110px; }
    .dance-header { height: 44px; }
  }
</style>

<script>
  (function () {
    if (window.__danceInit) return;
    window.__danceInit = true;

    const mulberry32 = (a) => () => {
      a |= 0; a = (a + 0x6d2b79f5) | 0;
      let t = Math.imul(a ^ (a >>> 15), 1 | a);
      t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
      return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
    };
    const hashStr = (s) => {
      let h = 2166136261 >>> 0;
      for (let i = 0; i < s.length; i++) { h ^= s.charCodeAt(i); h = Math.imul(h, 16777619); }
      return h >>> 0;
    };
    const hex2rgb = (h) => {
      h = (h || '').replace('#', '').trim();
      if (h.length === 3) h = h.split('').map((c) => c + c).join('');
      const n = parseInt(h || '333333', 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    };
    const lerp = (a, b, t) => a + (b - a) * t;
    const mix = (c1, c2, t) => [lerp(c1[0], c2[0], t), lerp(c1[1], c2[1], t), lerp(c1[2], c2[2], t)];

    const css = getComputedStyle(document.documentElement);
    const PAL = [
      css.getPropertyValue('--ink'),
      css.getPropertyValue('--ink-soft'),
      css.getPropertyValue('--accent'),
    ].map(hex2rgb);

    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const dances = [];

    function build(canvas) {
      const variant = canvas.dataset.variant || 'header';
      const rng = mulberry32(hashStr(canvas.dataset.seed || 'a'));
      const n = variant === 'header' ? 3 : 4;
      const threads = [];
      for (let i = 0; i < n; i++) {
        const sgn = () => (rng() < 0.5 ? -1 : 1);
        threads.push({
          baseY: 0.32 + rng() * 0.36,
          amp: (variant === 'header' ? 0.08 : 0.12) + rng() * 0.10,
          f0: 0.5 + rng() * 1.3,
          f1: 1.1 + rng() * 2.2,
          p0: rng() * 6.283,
          p1: rng() * 6.283,
          s0: (0.10 + rng() * 0.15) * sgn(),
          s1: (0.08 + rng() * 0.12) * sgn(),
          ca: i % 3,
          cb: (i + 1 + (rng() * 2 | 0)) % 3,
          ct: rng() * 6.283,
          cs: 0.05 + rng() * 0.06,
          w: (variant === 'header' ? 0.9 : 1.15) + rng() * 0.45,
          a: (i === n - 1 ? 0.72 : 0.5) + rng() * 0.1,
        });
      }
      const d = { canvas, ctx: canvas.getContext('2d'), threads, w: 0, h: 0, vis: true };
      const resize = () => {
        const r = canvas.getBoundingClientRect();
        d.w = Math.max(1, r.width); d.h = Math.max(1, r.height);
        canvas.width = Math.round(d.w * dpr); canvas.height = Math.round(d.h * dpr);
        d.ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      };
      resize();
      window.addEventListener('resize', resize, { passive: true });
      if ('IntersectionObserver' in window) {
        new IntersectionObserver((es) => { d.vis = es[0].isIntersecting; }, { rootMargin: '120px' }).observe(canvas);
      }
      dances.push(d);
      if (reduce) drawOne(d, 4.0);
    }

    function drawOne(d, t) {
      const { ctx, w, h, threads } = d;
      ctx.clearRect(0, 0, w, h);
      const steps = Math.max(24, Math.floor(w / 8));
      for (const th of threads) {
        const ph0 = th.p0 + t * th.s0;
        const ph1 = th.p1 + t * th.s1;
        const ctm = 0.5 - 0.5 * Math.cos(th.ct + t * th.cs);
        const col = mix(PAL[th.ca], PAL[th.cb], ctm);
        ctx.beginPath();
        for (let i = 0; i <= steps; i++) {
          const x = i / steps, px = x * w;
          const y = (th.baseY + th.amp * (Math.sin(th.f0 * 6.283 * x + ph0) + 0.5 * Math.sin(th.f1 * 6.283 * x + ph1))) * h;
          if (i) ctx.lineTo(px, y); else ctx.moveTo(px, y);
        }
        ctx.strokeStyle = `rgba(${col[0] | 0},${col[1] | 0},${col[2] | 0},${th.a})`;
        ctx.lineWidth = th.w; ctx.lineCap = 'round'; ctx.lineJoin = 'round';
        ctx.stroke();
      }
    }

    let start = null;
    function loop(ts) {
      if (start === null) start = ts;
      const t = (ts - start) / 1000;
      for (const d of dances) if (d.vis) drawOne(d, t);
      requestAnimationFrame(loop);
    }

    function init() {
      document.querySelectorAll('canvas[data-dance]').forEach(build);
      const body = document.querySelector('.essay-body');
      if (body) {
        body.querySelectorAll('h2').forEach((hd) => {
          const c = document.createElement('canvas');
          c.className = 'drawing-dance dance-header';
          c.setAttribute('data-dance', '');
          c.setAttribute('aria-hidden', 'true');
          c.dataset.variant = 'header';
          c.dataset.seed = (hd.textContent || 'section').slice(0, 80);
          hd.insertAdjacentElement('afterend', c);
          build(c);
        });
      }
      if (!reduce) requestAnimationFrame(loop);
    }

    if (document.readyState !== 'loading') init();
    else document.addEventListener('DOMContentLoaded', init);
  })();
</script>
