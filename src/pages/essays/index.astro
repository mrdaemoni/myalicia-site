---
import Base from '../../layouts/Base.astro';
import DrawingDance from '../../components/DrawingDance.astro';
import { frontmatter as ee } from '../../essays/emergence-vs-emergency.md';
import { frontmatter as hp } from '../../essays/the-humorphic-partnership.md';

// Newest first.
const essays = [ee, hp];
---
<Base
  title="Essays · My Alicia"
  description="Long-form pieces on design rationale, lived moments, and the philosophical lineage of My Alicia. Each one is signed and dated."
>
  <h1>Essays</h1>
  <p class="lede">
    Long-form pieces on design rationale, lived moments, and the
    philosophical lineage of My Alicia. Each one is signed and dated.
  </p>

  <ul class="essay-list">
    {essays.map((fm) => (
      <li class="essay-list-item">
        <a class="essay-list-title" href={`/essays/${fm.slug}/`}>{fm.title}</a>
        <p class="essay-list-dek">{fm.dek}</p>
        <p class="essay-list-meta">{fm.date}</p>
        <a class="dance-link" href={`/essays/${fm.slug}/`} aria-label={`Read ${fm.title}`} tabindex="-1">
          <DrawingDance seed={fm.title} variant="card" />
        </a>
      </li>
    ))}
  </ul>
</Base>

<style>
  .essay-list {
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 0;
  }
  .essay-list-item {
    padding: 1.75rem 0;
    border-top: 1px solid var(--rule);
  }
  .essay-list-item:last-child {
    border-bottom: 1px solid var(--rule);
  }
  .essay-list-title {
    font-size: 1.6rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--ink);
    text-decoration: none;
  }
  .essay-list-title:hover { color: var(--accent); text-decoration: none; }
  .essay-list-dek {
    font-size: 1.05rem;
    color: var(--ink-soft);
    margin: 0.5rem 0 0.4rem;
  }
  .essay-list-meta {
    font-size: 0.9rem;
    color: var(--ink-soft);
    margin: 0;
  }
</style>
