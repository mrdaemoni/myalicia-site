---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'My Alicia — the human interface, made buildable',
  description = 'My Alicia is an AI teammate that collaborates with you on your learning journey, transforming knowledge into wisdom. The tangible example of humorphism.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>
      :root {
        --bg: #fafaf7;
        --bg-soft: #f3f1ec;
        --ink: #1a1a1a;
        --ink-soft: #555550;
        --accent: #d97757;
        --rule: #e6e3dc;
        --max: 720px;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
        font-family: ui-sans-serif, -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
        font-size: 17px;
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
      }
      main {
        max-width: var(--max);
        margin: 0 auto;
        padding: 4rem 1.5rem 6rem;
      }
      h1, h2, h3 {
        font-weight: 600;
        line-height: 1.25;
        letter-spacing: -0.01em;
      }
      h1 { font-size: 2.4rem; margin: 0 0 0.5rem; }
      h2 { font-size: 1.4rem; margin: 3rem 0 1rem; }
      h3 { font-size: 1.1rem; margin: 2rem 0 0.5rem; }
      p { margin: 0 0 1.25rem; }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      .lede {
        font-size: 1.1rem;
        color: var(--ink-soft);
        margin: 0 0 2.5rem;
      }
      .rule {
        height: 1px;
        background: var(--rule);
        border: none;
        margin: 3rem 0;
      }
      .figure {
        margin: 2rem -0.5rem;
        background: var(--bg-soft);
        border: 1px solid var(--rule);
        border-radius: 8px;
        padding: 1.25rem;
      }
      .figure svg { display: block; max-width: 100%; height: auto; }
      .caption {
        font-size: 0.9rem;
        color: var(--ink-soft);
        margin: 0.75rem 0 0;
        text-align: center;
      }
      .cta {
        display: inline-block;
        background: var(--ink);
        color: var(--bg);
        padding: 0.75rem 1.25rem;
        border-radius: 6px;
        font-weight: 500;
        margin: 1rem 0;
      }
      .cta:hover { text-decoration: none; opacity: 0.9; }
      nav.top {
        max-width: var(--max);
        margin: 0 auto;
        padding: 1.5rem 1.5rem 0;
        font-size: 0.95rem;
      }
      nav.top a { color: var(--ink-soft); margin-right: 1.5rem; }
      footer {
        max-width: var(--max);
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
        font-size: 0.9rem;
        color: var(--ink-soft);
      }
    </style>
  </head>
  <body>
    <nav class="top">
      <a href="/">My Alicia</a>
      <a href="/philosophy">philosophy</a>
      <a href="/architecture">architecture</a>
      <a href="https://github.com/mrdaemoni/myalicia">github</a>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      <p>
        My Alicia is the tangible example of <a href="https://humorphism.com">humorphism</a>.
        Built on <a href="https://github.com/garrytan">Garry Tan</a>'s thin-harness pattern
        and <a href="https://github.com/karpathy">Andrej Karpathy</a>'s autoresearch idea.
        MIT licensed.
      </p>
    </footer>
  </body>
</html>
